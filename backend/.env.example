# ==========================================
# TradeMind API Environment Configuration
# ==========================================

# Application
NODE_ENV=development
PORT=5000
API_VERSION=v1
API_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-change-this-in-production
BCRYPT_ROUNDS=12

# Database - MongoDB
MONGODB_URI=mongodb://localhost:27017/trademind
MONGODB_URI_TEST=mongodb://localhost:27017/trademind_test

# Cache - Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Email - SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@trademind.app
EMAIL_FROM_NAME=TradeMind

# OAuth - Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# OAuth - GitHub
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:5000/api/v1/auth/github/callback

# AI - OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Storage - AWS S3 or MinIO
STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=trademind-uploads

# OR MinIO (for local development)
# STORAGE_PROVIDER=minio
# MINIO_ENDPOINT=localhost
# MINIO_PORT=9000
# MINIO_USE_SSL=false
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=trademind-uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# Features
ENABLE_AI=true
ENABLE_EMAIL=true
ENABLE_OAUTH=true
